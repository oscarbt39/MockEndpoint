      "id": "ec2f86ee-a1f3-4cf2-b8df-59afae019b2e",
      "name": "Basic LLM Chain1"
    },
    {
      "parameters": {
        "jsCode": "const cleanText = $json.text.replace(/```json/g, '').replace(/```/g, '').trim();\nconst parsed = JSON.parse(cleanText);\n\n// Si response_body no es un objeto, lo metemos dentro de uno\nlet finalBody = parsed.response_body;\nif (typeof finalBody !== 'object' || finalBody === null) {\n  finalBody = { data: finalBody };\n}\n\nreturn {\n  path: parsed.path,\n  method: parsed.method,\n  response_body: finalBody, // Ahora siempre es un objeto {}\n  status_code: parsed.status_code\n};"
      },
